        "type": "inject",
        "z": "2fd54c5f0db04e4b",
        "name": "Create Phased Response",
        "props": [
            {
                "p": "ai.model",
                "v": "gpt-5.4",
                "vt": "str"
            },
            {
                "p": "ai.prompt_cache_key",
                "v": "responses-phase-example-v1",
